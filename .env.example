# ─── MetaAPI (REQUIRED) ──────────────────────────────────────────────────────
# Register at https://app.metaapi.cloud (free tier available)
# 1. Sign up / log in
# 2. Go to "MT Accounts" → Add Account → enter your XM credentials
# 3. Copy the Account ID shown after adding
# 4. Go to "API Access" → copy your API Token

METAAPI_TOKEN=your_token_here
METAAPI_ACCOUNT_ID=your_account_id_here

# ─── Database ────────────────────────────────────────────────────────────────
FOREXBOT_DB_PATH=/app/trading_system/data/trades.db

# ─── Trading bot config ──────────────────────────────────────────────────────
# These mirror what's in trading_system/config.yaml
# Set DEMO_MODE=true while testing — prevents real money trades
DEMO_MODE=true
